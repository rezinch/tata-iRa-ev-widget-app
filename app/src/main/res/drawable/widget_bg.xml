<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Deep dark base with slight blue tint -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#E6101820" />
            <corners android:radius="20dp" />
        </shape>
    </item>
    <!-- Frosted glass sheen — diagonal gradient -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#28FFFFFF"
                android:centerColor="#10FFFFFF"
                android:endColor="#04FFFFFF"
                android:angle="135"
                android:type="linear" />
            <corners android:radius="20dp" />
        </shape>
    </item>
    <!-- Teal glow border -->
    <item>
        <shape android:shape="rectangle">
            <stroke android:width="1dp" android:color="#5500A3A1" />
            <corners android:radius="20dp" />
        </shape>
    </item>
</layer-list>
